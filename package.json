{
  "name": "@wazoo/api",
  "version": "0.1.0",
  "description": "TypeScript client for the Wazoo Platform API generated from OpenAPI.",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./openapi.json": "./openapi/openapi.json"
  },
  "files": [
    "src",
    "openapi/openapi.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "sync:openapi": "tsx scripts/sync-openapi.mjs",
    "generate": "openapi-ts",
    "build": "tsc -p tsconfig.json",
    "check": "npm run sync:openapi && npm run generate && npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "wazoo",
    "api",
    "openapi",
    "typescript",
    "generated-client"
  ],
  "license": "MIT",
  "devDependencies": {
    "@hey-api/openapi-ts": "0.98.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2"
  }
}
